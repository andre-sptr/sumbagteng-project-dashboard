# --- GOOGLE AUTHENTICATION ---
# Path to Google Service Account JSON file OR raw JSON string credentials
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# GOOGLE_CREDENTIALS='{"type": "service_account", ...}'

# --- APPLICATION CONFIGURATION ---
NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- DATABASE CONFIGURATION ---
# Path to SQLite database file (relative to project root)
DATABASE_PATH=./data/projects.db

# --- GOOGLE SHEETS SYNC ---
# Extract from Sheet URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit#gid={SHEET_ID}
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_ID=your_sheet_id_here

# --- BACKGROUND SERVICES & WEBSOCKETS ---
# Enable background sync scheduler and Socket.IO in local dev
ENABLE_BACKGROUND_SERVICES=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
# NEXT_PUBLIC_WS_URL=http://localhost:3001

# --- THIRD-PARTY APIS (OPTIONAL) ---
# API_KEY=your_api_key_here

# --- WHATSAPP ALERTS (WAHA) ---
# Sends alerts for at-risk projects. Requires ENABLE_BACKGROUND_SERVICES=true.
WAHA_ALERT_ENABLED=false
WAHA_URL=https://your-waha-instance.example.com
WAHA_SESSION=your_session_name
WAHA_API_KEY=your_api_key_here
# Comma-separated WhatsApp Group IDs (e.g. 120363142428170648@g.us)
WAHA_GROUP_IDS=